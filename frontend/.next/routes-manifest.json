    },
    {
      "page": "/collections",
      "regex": "^/collections(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/collections(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/legal",
      "regex": "^/legal(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/legal(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
